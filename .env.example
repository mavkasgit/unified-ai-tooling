# Copy to ~/.config/ai/.env and fill in (never commit .env)

# Postgres MCP connection string (postgresql://, not postgresql+asyncpg://)
POSTGRES_MCP_URL=postgresql://user:password@localhost:5432/dbname

# Default workspace for Antigravity codegraph substitution
WORKSPACE_FOLDER=C:\Users\user\VibeCoding\ktm2000

# Optional API keys (enhanced access)
# EXA_API_KEY=
# CONTEXT7_API_KEY=